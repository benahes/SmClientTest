# Server
NODE_ENV=development
PORT=8080

# CORS
# Comma-separated origins. For local device testing with adb reverse, this can stay *
# Example for web clients: CORS_ORIGIN=http://localhost:3000,https://app.example.com
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Firebase Admin (required for real token verification)
# Fill from Firebase service account and Railway environment variables.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Dev fallback: allow mock auth when Firebase Admin credentials are not set.
# NEVER enable this in production.
ENABLE_AUTH_MOCK=true

# Local persistent file store for users module
USER_DATA_FILE=data/users.json
